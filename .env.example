# ── Django ────────────────────────────────────────────────────────────────────
SECRET_KEY=substitua-por-uma-chave-real
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0



# ── Seleção de banco ──────────────────────────────────────────────────────────
# Valores aceitos: "sqlite" | "postgres" | "mysql"
# SQLite (default — no profile needed)
DB=sqlite


# PostgreSQL (comente todos os outros e descomente as linhas abaixo, utilize o profile postgres no docker compose)

# DB=postgres
# DB_HOST=postgres
# DB_PORT=5432
# DB_NAME=django_db
# DB_USER=django_user
# DB_PASSWORD=django_password


# MySQL (comente todos os outros e descomente as linhas abaixo, utilize o profile mysql no docker compose)

# DB=mysql
# DB_HOST=mysql
# DB_PORT=3306
# DB_NAME=django_db
# DB_USER=django_user
# DB_PASSWORD=django_password
# MYSQL_ROOT_PASSWORD=django_root_password
